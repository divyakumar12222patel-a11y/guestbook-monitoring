{
  "name": "guestbook-monitoring",
  "version": "1.0.0",
  "description": "Pulumi Kubernetes Guestbook with Prometheus/Grafana monitoring",
  "main": "index.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint 'infra/**/*.ts' --ext .ts",
    "format": "prettier --write 'infra/**/*.ts'",
    "test": "jest",
    "validate": "bash scripts/validate.sh",
    "deploy": "pulumi up --yes",
    "destroy": "pulumi destroy --yes",
    "preview": "pulumi preview"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  },
  "dependencies": {
    "@pulumi/pulumi": "^3.0.0",
    "@pulumi/kubernetes": "^4.0.0",
    "@pulumi/random": "^4.0.0"
  }
}
